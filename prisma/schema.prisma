generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum AccountMode {
  CONSUMER
  PROVIDER
  BOTH
}

enum ProfileKind {
  MODEL
  OPERATOR
  STUDIO
  AGENCY
  EXPERT
  COACH
  LAWYER
  OTHER
}

enum ArticleKind {
  BLOG
  EXPERT
  PROMO
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
}

enum ListingType {
  VACANCY
  SERVICE
}

enum EmploymentType {
  REMOTE
  OFFICE
  HYBRID
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentType {
  ARTICLE_SLOT
  VACANCY_PUBLICATION
  SERVICE_PUBLICATION
  RESUME_UNLOCK
}

enum ReportTargetType {
  ARTICLE
  COMMENT
  PROFILE
  LISTING
  PRODUCT
  RESUME
  MATCH_PROFILE
  INVITE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum BalanceTxType {
  TOP_UP
  HOLD
  CHARGE
  REFUND
}

enum AdvertisementStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ProductCondition {
  NEW
  GOOD
  USED
  NEEDS_REPAIR
}

enum ProductDelivery {
  CITY_ONLY
  DELIVERY
  ANY
}

enum ReportStatus {
  PENDING_REVIEW
  HIDDEN
  RESOLVED
}

model User {
  id               String      @id @default(cuid())
  name             String?
  email            String?     @unique
  emailVerified    DateTime?
  image            String?
  profileBio       String?
  passwordHash     String?
  role             UserRole    @default(USER)
  accountMode      AccountMode @default(CONSUMER)
  profileKind      ProfileKind @default(MODEL)
  tgHandle         String?
  isAdultConfirmed Boolean     @default(false)
  lastActiveAt       DateTime    @default(now())
  blockedUntil       DateTime?
  blockedPermanently Boolean     @default(false)
  blockReason        String?
  createdAt          DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  articles         Article[]
  listings         Listing[]
  resume           Resume?
  payments         Payment[]
  unlocks          ResumeContactUnlock[]
  articleComments  ArticleComment[]
  articleRatings   ArticleRating[]
  commentLikes     CommentLike[]
  listingReviews   ListingReview[]
  reports          Report[]
  reviewedReports  Report[]              @relation("ReviewedReports")
  authorFollowers  Follow[]              @relation("AuthorFollowers")
  followingAuthors Follow[]              @relation("AuthorFollowing")
  topicFollows     TopicFollow[]
  savedListings    SavedListing[]
  savedResumes     SavedResume[]
  products         Product[]
  savedProducts    SavedProduct[]
  matchProfile     MatchProfile?
  savedMatchProfiles SavedMatchProfile[]
  studioInvites       Invite[]             @relation("StudioInvites")
  modelInvites        Invite[]             @relation("ModelInvites")
  studioBalance       StudioBalance?
  balanceTransactions BalanceTransaction[]
  violationCount      Int                  @default(0)
  advertisements      Advertisement[]
  auditLogs           AuditLog[]           @relation("AuditLogs")

  accounts Account[]
  sessions Session[]
}

model Article {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  kind          ArticleKind   @default(BLOG)
  format        String?
  topic         String?
  coverImage    String?
  summary       String
  body          String
  status        ContentStatus @default(PENDING_REVIEW)
  hiddenReason  String?
  isEditorPick  Boolean       @default(false)
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  publishedAt   DateTime?
  viewCount     Int           @default(0)
  responseCount Int           @default(0)
  repostCount   Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  expertSlots ExpertSlot[]
  comments    ArticleComment[]
  ratings     ArticleRating[]

  @@index([status, publishedAt])
  @@index([topic, status])
}

model ArticleComment {
  id           String           @id @default(cuid())
  articleId    String
  article      Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       ArticleComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      ArticleComment[] @relation("CommentReplies")
  body         String
  isHidden     Boolean          @default(false)
  hiddenReason String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  likes        CommentLike[]

  @@index([articleId, createdAt])
  @@index([parentId, createdAt])
}

model ArticleRating {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([articleId, userId])
  @@index([articleId])
}

model CommentLike {
  id        String         @id @default(cuid())
  commentId String
  comment   ArticleComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
}

model ExpertSlot {
  id               String   @id @default(cuid())
  articleId        String
  article          Article  @relation(fields: [articleId], references: [id])
  geoCode          String
  title            String
  specialization   String
  contact          String
  vacanciesUrl     String?
  isRemoteFallback Boolean  @default(false)
  startsAt         DateTime
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([articleId, geoCode, expiresAt])
}

model Listing {
  id             String          @id @default(cuid())
  type           ListingType
  title          String
  slug           String?         @unique
  description    String
  city           String?
  geoCode        String?
  employmentType EmploymentType?
  contact        String
  status         ContentStatus   @default(PENDING_REVIEW)
  hiddenReason   String?
  viewCount      Int             @default(0)
  responseCount  Int             @default(0)
  expiresAt      DateTime?
  createdById    String
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  savedBy        SavedListing[]
  reviews        ListingReview[]

  @@index([type, status, createdAt])
}

model ListingReview {
  id           String          @id @default(cuid())
  listingId    String
  listing      Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId     String?
  parent       ListingReview?  @relation("ListingReviewReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      ListingReview[] @relation("ListingReviewReplies")
  rating       Int?
  body         String
  isHidden     Boolean         @default(false)
  hiddenReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([listingId, createdAt])
  @@index([parentId, createdAt])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  follower   User     @relation("AuthorFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation("AuthorFollowers", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([followerId, authorId])
  @@index([authorId])
}

model TopicFollow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     String
  createdAt DateTime @default(now())

  @@unique([userId, topic])
  @@index([topic])
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}

model Product {
  id            String           @id @default(cuid())
  title         String
  category      String
  priceRub      Int
  city          String?
  delivery      ProductDelivery  @default(ANY)
  condition     ProductCondition @default(GOOD)
  description   String
  contact       String
  imageUrl      String?
  status        ContentStatus    @default(PUBLISHED)
  hiddenReason  String?
  viewCount     Int              @default(0)
  responseCount Int              @default(0)
  expiresAt     DateTime?
  createdById   String
  createdBy     User             @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  savedBy       SavedProduct[]

  @@index([status, createdAt])
  @@index([category, status])
  @@index([createdById, createdAt])
}

model SavedProduct {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([productId])
}

model Advertisement {
  id          String              @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  targetUrl   String
  placement   String
  status      AdvertisementStatus @default(ACTIVE)
  clickCount  Int                 @default(0)
  startsAt    DateTime?
  expiresAt   DateTime?
  createdById String
  createdBy   User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([placement, status])
  @@index([expiresAt])
  @@index([createdById, createdAt])
}

model Report {
  id           String           @id @default(cuid())
  targetType   ReportTargetType
  targetId     String
  reason       String
  status       ReportStatus     @default(PENDING_REVIEW)
  reporterId   String
  reporter     User             @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedById String?
  reviewedBy   User?            @relation("ReviewedReports", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([targetType, targetId])
  @@index([status, createdAt])
}

model Resume {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id])
  title              String
  bio                String
  city               String?
  roleGoal           String
  experienceMonths   Int       @default(0)
  contactEmail       String?
  contactTelegram    String?
  viewCount          Int       @default(0)
  responseCount      Int       @default(0)
  isPublic           Boolean   @default(true)
  hiddenByInactivity Boolean   @default(false)
  lastVisitedAt      DateTime  @default(now())
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  unlocks ResumeContactUnlock[]
  savedBy SavedResume[]
  invites Invite[]

  @@index([isPublic, hiddenByInactivity, expiresAt])
}

model SavedResume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, resumeId])
  @@index([resumeId])
}

model MatchProfile {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  seekerRole      String
  lookingFor      String
  title           String
  city            String?
  timezone        String?
  experience      String
  schedule        String
  operatorPercent String?
  currentCheck    String?
  niche           String?
  workFormat      String
  bio             String
  contact         String
  status          ContentStatus @default(PUBLISHED)
  hiddenReason    String?
  viewCount       Int           @default(0)
  responseCount   Int           @default(0)
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  savedBy         SavedMatchProfile[]

  @@index([status, updatedAt])
  @@index([seekerRole, lookingFor, status])
  @@index([city, status])
}

model SavedMatchProfile {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchProfileId String
  matchProfile   MatchProfile @relation(fields: [matchProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, matchProfileId])
  @@index([matchProfileId])
}

model ResumeContactUnlock {
  id         String   @id @default(cuid())
  resumeId   String
  resume     Resume   @relation(fields: [resumeId], references: [id])
  studioId   String
  studio     User     @relation(fields: [studioId], references: [id])
  unlockedAt DateTime @default(now())
  expiresAt  DateTime

  @@index([resumeId, studioId, expiresAt])
}

model Payment {
  id              String        @id @default(cuid())
  payerId         String
  payer           User          @relation(fields: [payerId], references: [id])
  type            PaymentType
  amountUsd       Decimal       @db.Decimal(10, 2)
  txHash          String?
  receiptImageUrl String?
  status          PaymentStatus @default(PENDING)
  rejectionReason String?
  referenceType   String
  referenceId     String
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([referenceType, referenceId])
  @@index([status, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invite {
  id              String       @id @default(cuid())
  resumeId        String
  resume          Resume       @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  studioId        String
  studio          User         @relation("StudioInvites", fields: [studioId], references: [id], onDelete: Cascade)
  modelId         String
  model           User         @relation("ModelInvites", fields: [modelId], references: [id], onDelete: Cascade)
  status          InviteStatus @default(PENDING)
  quizAnswers     String
  message         String
  offeredPercent  Int?
  amountUsd       Int          @default(15)
  holdTxId        String?
  declineReason   String?
  respondedAt     DateTime?
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([resumeId, studioId])
  @@index([modelId, status])
  @@index([status, expiresAt])
}

model StudioBalance {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableUsd  Int      @default(0)
  holdUsd       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BalanceTransaction {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        BalanceTxType
  amountCents Int
  inviteId    String?
  note        String?
  createdAt   DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([inviteId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("AuditLogs", fields: [userId], references: [id], onDelete: Cascade)
  action     String
  targetType String
  targetId   String
  details    String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}
